# ──────────────────────────────────────────────────────────────────────────────
# Tcher Ayu — environment variables
#
# Local dev: copy to `.env` (or `server/.env`) and fill in.
# Production: these are injected by the GitHub Actions deploy workflow
#             from repository secrets — see .github/workflows/deploy.yml
# ──────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Domain (production only, used by Caddy for HTTPS) ───────────────────────
# e.g. tcherayu.com
DOMAIN=

# ── Database (Postgres) ──────────────────────────────────────────────────────
# Local dev
DATABASE_URL=postgresql://user:password@localhost:5432/smarttutor
# Production docker-compose uses these to build DATABASE_URL internally
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
SESSION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── AI ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Text-to-speech ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CERDAS_PRICE_ID=
STRIPE_CEMERLANG_PRICE_ID=

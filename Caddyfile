# ──────────────────────────────────────────────────────────────────────────────
# Caddy reverse proxy — automatic HTTPS via Let's Encrypt
#
# The {$DOMAIN} placeholder is substituted from the `caddy` service env.
# Caddy listens on :80 and :443, proxies everything to the `web` nginx
# container (which serves the SPA and proxies /api/ to the server container).
# ──────────────────────────────────────────────────────────────────────────────

{$DOMAIN} {
    encode gzip zstd

    # Allow large uploads (images for question capture)
    request_body {
        max_size 12MB
    }

    reverse_proxy web:80 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Reasonable security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output stdout
        format console
    }
}
